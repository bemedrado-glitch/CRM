# ═══════════════════════════════════════════════════════════
# FILVEO ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ═══════════════════════════════════════════════════════════

# ── Supabase (NEW dedicated Filveo project)
# Create at: https://supabase.com/dashboard/projects
# This must be a brand new project — NOT shared with any other app
FILVEO_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
FILVEO_SUPABASE_ANON_KEY=your_anon_key_here

# ── Stripe (to be added)
# STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# STRIPE_SECRET_KEY=sk_live_xxx  # Never expose client-side
# STRIPE_PRICE_SOLO=price_xxx    # $39/month Solo plan
# STRIPE_PRICE_STUDIO=price_xxx  # $89/month Studio plan
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Email (to be added — for transactional emails)
# SENDGRID_API_KEY=SG.xxx
# FROM_EMAIL=hello@filveo.com

# ── Analytics (when ready — optional)
# POSTHOG_KEY=phc_xxx
# POSTHOG_HOST=https://app.posthog.com

# ── Domain
FILVEO_URL=https://filveo.com
FILVEO_APP_URL=https://app.filveo.com
