      </div>
    </div>

    <!-- App frame -->
    <div class="fpane" id="p-app">
      <div class="loader" id="l-app"><div class="spin"></div><div class="lbl">Loading CRM Application…</div></div>
      <iframe id="f-app" title="CRM App" allowfullscreen></iframe>
    </div>

    <!-- Demo frame -->
    <div class="fpane" id="p-demo">
      <div class="loader" id="l-demo"><div class="spin"></div><div class="lbl">Loading Demo…</div></div>
      <iframe id="f-demo" title="Demo" allowfullscreen></iframe>
    </div>

    <!-- GTM frame -->
    <div class="fpane" id="p-gtm">
      <div class="loader" id="l-gtm"><div class="spin"></div><div class="lbl">Loading GTM Bible…</div></div>
      <iframe id="f-gtm" title="GTM Bible" allowfullscreen></iframe>
