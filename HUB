  </div><!-- /content -->

  <!-- Status bar -->
  <div class="sbar">
    <div class="si"><div class="sdot"></div> Filveo v4.0 · 2026</div>
    <div class="si">Solo $39/mo · Studio $89/mo</div>
    <div style="flex:1"></div>
    <div id="spath">hub.html</div>
  </div>

</div><!-- /app -->

<script>
  // ── File paths from project root ──────────────────────────
  // hub.html must sit at the project root (same level as src/ and docs/)
  const PATHS = {
    app:     'src/app.html',
    demo:    'src/demo.html',
    gtm:     'docs/gtm-bible-v4.html',
    landing: 'src/index.html',
  };
  const LABELS = {
    home:    'Command Center',
    app:     'CRM Application',
    demo:    'Interactive Demo — Sofia Reyes · 16 scenes',
    gtm:     'GTM Bible v4 — strategy, sequences, prospects',
    landing: 'Landing Page — public site',
  };

  // ── Detect file:// protocol ───────────────────────────────
  if (location.protocol === 'file:') {
    document.getElementById('setup').classList.add('show');
  } else {
    document.getElementById('app').classList.add('show');
  }

  // ── Navigation ────────────────────────────────────────────
  const loaded = {};
  let   active = 'home';

  function go(id) {
    // Deactivate previous
    document.getElementById('p-' + active)?.classList.remove('on');
    document.getElementById('t-' + active)?.classList.remove('on');

    active = id;

    // Activate
    document.getElementById('p-' + id)?.classList.add('on');
    document.getElementById('t-' + id)?.classList.add('on');

    // Update labels
    const lbl = document.getElementById('cur');
    lbl.innerHTML = id === 'home' ? 'Command Center' : '<b>' + LABELS[id] + '</b>';
    document.getElementById('spath').textContent = id === 'home' ? 'hub.html' : (PATHS[id] || '');

    // Pop-out button
    const pb = document.getElementById('popbtn');
    pb.classList.toggle('show', id !== 'home');

    // Load iframe once
    if (id !== 'home' && !loaded[id]) {
      loaded[id] = true;
      const frame = document.getElementById('f-' + id);
      if (frame) {
        frame.src = PATHS[id];
        frame.addEventListener('load', () => {
          document.getElementById('l-' + id)?.classList.add('gone');
        }, { once: true });
        // Fallback: hide loader after 8s regardless
        setTimeout(() => document.getElementById('l-' + id)?.classList.add('gone'), 8000);
      }
    }
  }

  function popout() {
    if (active !== 'home' && PATHS[active]) {
      window.open(PATHS[active], '_blank');
    }
  }

  // Keyboard: ` = hub, 1-4 = pages
  document.addEventListener('keydown', e => {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    const map = { '`':'home', '1':'app', '2':'demo', '3':'gtm', '4':'landing' };
    if (map[e.key]) go(map[e.key]);
  });
</script>
</body>
</html>
